{
  "protected_paths": [
    "/etc/passwd",
    "/etc/shadow",
    "/etc/sudoers",
    "/etc/ssh/sshd_config",
    "/etc/fstab",
    "/etc/hosts",
    "/boot",
    "/usr/bin",
    "/usr/sbin",
    "/bin",
    "/sbin",
    "/lib",
    "/usr/lib",
    "C:\\Windows",
    "C:\\Windows\\System32"
  ],
  "high_risk_patterns": [
    "rm -rf /",
    "rm -rf /*",
    "rm -rf ~",
    "rm -rf /home",
    "rm -rf /var",
    "rm -rf /etc",
    "rm -rf /tmp/.*",
    "mkfs",
    "format",
    "dd if=/dev/zero",
    "dd if=/dev/random",
    ":(){ :|:& };:",
    "chmod -R 777 /",
    "chmod 000",
    "chmod 777",
    "chown -R",
    "userdel root",
    "userdel admin",
    "passwd root",
    "shutdown",
    "reboot",
    "init 0",
    "init 6",
    "halt",
    "poweroff",
    "systemctl disable",
    "systemctl stop sshd",
    "systemctl stop firewall",
    "systemctl stop firewalld",
    "systemctl mask",
    "iptables -F",
    "ufw disable",
    "> /dev/sda",
    "> /etc/",
    "mv /etc",
    "kill -9 1",
    "killall",
    "pkill -9",
    "echo '' > /var/log",
    "truncate -s 0",
    "find / -delete",
    "find / -exec rm",
    "scp /etc",
    "nc -l",
    "ncat -l",
    "python -c 'import os;os.system'",
    "base64 -d | sh",
    "wget | sh",
    "curl | sh",
    "wget | bash",
    "curl | bash"
  ],
  "confirmation_actions": [
    "file.delete",
    "file.move",
    "process.kill",
    "user.create",
    "user.delete",
    "user.modify",
    "system.reboot",
    "system.shutdown",
    "disk.format",
    "network.firewall"
  ],
  "max_command_length": 1000,
  "max_batch_operations": 10,
  "max_search_results": 50,
  "blocked_commands": [
    "curl | sh",
    "curl | bash",
    "wget | sh",
    "wget | bash",
    "rm -rf /",
    "rm -rf /*",
    ":(){ :|:& };:",
    "chmod -R 777 /"
  ],
  "environment_risk_multipliers": {
    "production": 1.5,
    "staging": 1.2,
    "development": 1.0,
    "unknown": 1.0
  },
  "risk_levels": {
    "LOW": 0,
    "MEDIUM": 1,
    "HIGH": 2,
    "CRITICAL": 3
  }
}
